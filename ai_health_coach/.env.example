# Required
ANTHROPIC_API_KEY=sk-ant-...

# Database (default: SQLite on Railway volume)
# Local dev: sqlite+aiosqlite:///./health_coach.db
# Railway:   sqlite+aiosqlite:////data/health_coach.db (default)
DATABASE_URL=sqlite+aiosqlite:////data/health_coach.db

# Optional: LangSmith tracing
LANGSMITH_API_KEY=
LANGCHAIN_TRACING_V2=false

# Feature flags
CONSENT_CHECK_ENABLED=true

# API auth (required — generate with: openssl rand -hex 16)
API_KEY=
